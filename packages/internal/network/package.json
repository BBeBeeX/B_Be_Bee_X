      "require": "./src/cache.ts",
      "import": "./src/cache.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "require": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "require": "./src/errors.ts",
      "import": "./src/errors.ts"
    },
    "./logging": {
      "types": "./src/logging.ts",
      "require": "./src/logging.ts",
      "import": "./src/logging.ts"
    },
    "./pluginValidation": {
      "types": "./src/pluginValidation.ts",
