      "import": "./src/pluginValidation.ts"
    },
    "./proxy": {
      "types": "./src/proxy.ts",
      "require": "./src/proxy.ts",
      "import": "./src/proxy.ts"
    },
    "./proxyPersistence": {
      "types": "./src/proxyPersistence.ts",
      "require": "./src/proxyPersistence.ts",
